# Lumina Configuration
# Copy to .env and fill in values: cp .env.example .env

# Domain
DOMAIN=lumina.su

# Backend
LUMINA_HOST=0.0.0.0
LUMINA_PORT=8080
CORS_ORIGIN=https://lumina.su
# Secrets below must be >=32 bytes. Generate with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32
RUST_LOG=lumina_server=info

# Redis (auto-set by docker-compose, override for external Redis)
# REDIS_URL=redis://redis:6379

# TURN (coturn)
TURN_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32
TURN_SERVER=lumina.su
TURN_PORT=3478

# LiveKit — generate both with the install script; never commit real values.
LIVEKIT_API_KEY=CHANGE-ME-livekit-api-key
LIVEKIT_API_SECRET=CHANGE-ME-generate-with-openssl-rand-base64-48
LIVEKIT_URL=wss://lumina.su/livekit

# Limits
MAX_ROOMS=10000
MAX_PARTICIPANTS=100
ROOM_TTL_SECS=86400
RATE_LIMIT_PER_SEC=100
